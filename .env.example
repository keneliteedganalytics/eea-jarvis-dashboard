# Required: ElevenLabs API key for Jarvis voice
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# EEA v1: LLM handicapping engine. Set the provider you intend to use.
# These may also be set per-install in Settings; env takes precedence.
ANTHROPIC_API_KEY=
POE_API_KEY=

# Optional: override the SQLite database file (default data.db)
DATABASE_FILE=data.db

# Optional: server port (default 5000)
PORT=5000
