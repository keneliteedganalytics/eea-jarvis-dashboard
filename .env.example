# ── EEA Jarvis Dashboard environment ──────────────────────────────────────
# Copy to .env for local dev. In production (Railway), set the same vars
# in the Railway service Variables tab — do NOT commit a real .env.

# ── Required ──────────────────────────────────────────────────────────────
# ElevenLabs API key for Jarvis voice generation.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── LLM handicapping (Anthropic primary, Poe fallback) ────────────────────
# These can also be set per-install in Settings; env takes precedence.
ANTHROPIC_API_KEY=
POE_API_KEY=

# ── Voice (trackside "Hey Jarvis" live updates) ───────────────────────────
# Speech-to-text runs through ElevenLabs Scribe (reuses ELEVENLABS_API_KEY).
# Override the Scribe model or the persona LLM model here if needed; both
# have sensible defaults (scribe_v1 / claude-sonnet-4-5).
# ELEVENLABS_STT_MODEL=scribe_v1
# VOICE_LLM_MODEL=claude-sonnet-4-5

# ── Server ────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; locally we default to 5050 to avoid
# colliding with macOS AirPlay on 5000.
PORT=5050
# In production set NODE_ENV=production. Local dev leaves it unset.
# NODE_ENV=production

# ── Persistent storage ────────────────────────────────────────────────────
# On Railway, mount a volume at /data and point all three of these under it:
#   DATABASE_FILE=/data/database.db
#   AUDIO_DIR=/data/audio_cache
#   UPLOAD_DIR=/data/uploads
# Locally, leave them unset to use repo-local paths.
DATABASE_FILE=data.db
AUDIO_DIR=
UPLOAD_DIR=

# ── Optional: HTTP basic auth ─────────────────────────────────────────────
# When BOTH are set, the entire site (except /healthz) requires a login.
# Unset both for an open site (local dev).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
